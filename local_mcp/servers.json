{
    "sqlite": {
        "command": "uvx",
        "args": [
            "mcp-server-sqlite",
            "--db",
            "./memory/local_data.db"
        ]
    },
    "filesystem": {
        "command": "npx",
        "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "./"
        ]
    }
}